<!DOCTYPE html>
<html lang="am">
<head>
    <meta charset="UTF-8">
    <title>የዕድለኛው ገጽ</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; padding: 50px; background-color: #f0f2f5; }
        .card { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); display: inline-block; border-top: 8px solid #2ecc71; }
        h1 { color: #2ecc71; font-size: 40px; }
        p { font-size: 20px; color: #333; }
        .winner-box { background: #e8faf0; padding: 15px; border-radius: 10px; margin-top: 20px; }
        a { text-decoration: none; color: #3498db; font-weight: bold; }
    </style>
</head>
<body>
    <div class="card">
        <h1>🎉 እንኳን ደስ አለዎት! 🎉</h1>
        <div class="winner-box">
            <p><strong>ዕድለኛው፡</strong> <%= winner.fullName %></p>
            <p><strong>የቲኬት ቁጥር፡</strong> <%= winner.ticketNumber %></p>
            <p><strong>ስልክ፡</strong> <%= winner.phoneNumber %></p>
        </div>
        <br>
        <a href="/">ወደ መመዝገቢያ ገጽ ተመለስ</a>
    </div>
</body>
</html> 
<!DOCTYPE html>
<html lang="am">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>የዕለቱ አሸናፊ</title>
    <style>
        body { font-family: sans-serif; text-align: center; background: #fdfdfd; padding-top: 50px; }
        .winner-card { 
            border: 5px solid #ffc107; 
            display: inline-block; 
            padding: 40px; 
            border-radius: 20px; 
            background: white;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        h1 { color: #28a745; font-size: 40px; }
        .ticket { font-size: 50px; background: #ffc107; padding: 10px; border-radius: 10px; }
    </style>
</head>
<body>
    <div class="winner-card">
        <h1>🎉 የእለቱ አድለኛ 🎉</h1>
        <% if (winner) { %>
            <p style="font-size: 24px;">እንኳን ደስ አሎት <strong><%= winner.name %></strong>!</p>
            <p>የአሸናፊው ሎተሪ ቁጥር፦</p>
            <div class="ticket"><%= winner.ticketNumber %></div>
            <p>ስልክ ቁጥር፦ <%= winner.phone %></p>
        <% } else { %>
            <p>እስካሁን ምንም የተሸጠ ሎተሪ የለም።</p>
        <% } %>
        <br>
        <a href="/" style="text-decoration: none; color: #007bff;">ወደ መግቢያ ተመለስ</a>
    </div>
</body>
</html>
