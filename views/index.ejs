<!DOCTYPE html>
<html lang="am">
<head>
    <meta charset="UTF-8">
    <title>ኢትዮጵያ ሎተሪ</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; background-color: #f4f4f4; }
        .container { background: white; width: 300px; margin: 50px auto; padding: 20px; border-radius: 10px; box-shadow: 0px 0px 10px rgba(0,0,0,0.1); }
        input { width: 90%; padding: 10px; margin: 10px 0; border: 1px solid #ccc; border-radius: 5px; }
        button { width: 100%; padding: 10px; background-color: #28a745; color: white; border: none; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="container">
        <h2>ሎተሪ ይግዙ</h2>
        <form action="/buy" method="POST">
            <input type="text" name="name" placeholder="ሙሉ ስም" required>
            <input type="text" name="phone" placeholder="ስልክ ቁጥር" required>
            <button type="submit">ሎተሪ ቁጥርቁን ይቀበሉ</button>
        </form>
    </div>
</body>
</html>
